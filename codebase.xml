                            total_amount: parseFloat(paidRows[0].total_amount || 0)
                        },
                        combined: {
                            count: waitingRows[0].count + paidRows[0].count,
                            total_amount: parseFloat(waitingRows[0].total_amount || 0) + parseFloat(paidRows[0].total_amount || 0)
                        },
