                    mode: 'no-cors',
                    headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
                    body: JSON.stringify({ action: actionType }),
                }
            );
        } catch (e) {
            console.error('Network or fetch error:', e);
        }
    }, [token]);

